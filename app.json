{
  "expo": {
    "name": "ScoreTracker",
    "slug": "ScoreTrackerApp",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.asserai.scoretracker",
      "versionCode": 4,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2119923020720839~3474936061",
          "iosAppId": "ca-app-pub-2119923020720839~3474936061"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6e1e07a8-ce22-4332-9a72-1a4b24cc8926"
      }
    }
  }
}